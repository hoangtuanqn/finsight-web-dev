generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  password       String?
  googleId       String?   @unique
  facebookId     String?   @unique
  avatar         String?
  fullName       String
  monthlyIncome  Float     @default(0)
  extraBudget    Float     @default(0)
  level            String    @default("BASIC")
  levelExpiresAt   DateTime?
  strategyQuota    Int       @default(10)
  referralCode     String?   @unique
  referralCodeUsed String?
  commissionBalance Float    @default(0)
  totalCommissionEarned Float @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  twoFactorSecret String?
  isTwoFactorEnabled Boolean @default(false)
  twoFactorBackupCodes String?
  kycStatus            String    @default("NONE")
  kycVerifiedAt        DateTime?
  kycName              String?
  kycIdNumber          String?

  debts               Debt[]
  investorProfile     InvestorProfile?
  notifications       Notification[]
  debtSnapshots       DebtSnapshot[]
  chatSessions        ChatSession[]
  debtGoal            DebtGoal?
  transactions        Transaction[]
  aiStrategies        AIStrategy[]
  userPortfolio       UserPortfolio?
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  wallets             Wallet[]
  bankTransactionsPending BankTransactionPending[]
  referrals           Referral[]       @relation("Referrer")
  referredBy          Referral?        @relation("Referee")
  referralClicks      ReferralClick[]
  activities          UserActivity[]
  trustedDevices      TrustedDevice[]
  repaymentPlans      RepaymentPlan[]
  commissionLogs      CommissionLog[]  @relation("CommissionRecipient")
  bankAccounts        BankAccount[]
  withdrawalRequests  WithdrawalRequest[]
  kycRecord           KycRecord?
  faceDescriptors     FaceDescriptor[]

  @@map("users")
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  userAgent String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trusted_devices")
}

model Debt {
  id               String    @id @default(cuid())
  userId           String
  name             String
  platform         String
  debtType         String    @default("INSTALLMENT") // "INSTALLMENT" | "CREDIT_CARD"
  originalAmount   Float
  balance          Float
  apr              Float
  rateType         String    @default("FLAT")
  feeProcessing    Float     @default(0)
  feeInsurance     Float     @default(0)
  feeManagement    Float     @default(0)
  feePenaltyPerDay Float     @default(0)
  minPayment       Float
  dueDay           Int
  termMonths       Int
  remainingTerms   Int
  startDate        DateTime?
  status           String    @default("ACTIVE")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  deletedAt        DateTime?
  scheduledPurgeAt DateTime?
  deleteReason     String?
  deleteCommitment Boolean   @default(false)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
  repaymentPlanItems RepaymentPlanItem[]

  @@map("debts")
}

model Payment {
  id     String   @id @default(cuid())
  debtId String
  amount Float
  paidAt DateTime @default(now())
  notes  String?

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model InvestorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  capital       Float    @default(0)
  monthlyAdd    Float    @default(0)
  goal          String   @default("GROWTH")
  horizon       String   @default("MEDIUM")
  riskLevel     String   @default("MEDIUM")
  riskScore     Int      @default(0)
  savingsRate   Float    @default(6.0)
  inflationRate Float    @default(3.5)
  lastUpdated   DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations Allocation[]

  @@map("investor_profiles")
}

model Allocation {
  id             String   @id @default(cuid())
  profileId      String
  sentimentValue Int
  sentimentLabel String
  savings        Float
  gold           Float
  stocks         Float
  stocks_us      Float    @default(0)
  bonds          Float
  crypto         Float
  recommendation String
  createdAt      DateTime @default(now())

  profile InvestorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("allocations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  severity  String   @default("INFO")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DebtSnapshot {
  id           String   @id @default(cuid())
  userId       String
  totalDebt    Float
  totalEAR     Float
  debtToIncome Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debt_snapshots")
}

model DebtGoal {
  id         String   @id @default(cuid())
  userId     String   @unique
  targetDate DateTime
  strategy   String   @default("AVALANCHE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debt_goals")
}

model RepaymentPlan {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  strategy    String   @default("CUSTOM")
  extraBudget Float    @default(0)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items RepaymentPlanItem[]

  @@map("repayment_plans")
}

model RepaymentPlanItem {
  id        String   @id @default(cuid())
  planId    String
  debtId    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  plan RepaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  debt Debt          @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@unique([planId, debtId])
  @@map("repayment_plan_items")
}

// ── Subscription & Payment ──────────────────────────────────

model Transaction {
  id           String    @id @default(cuid())
  userId       String
  plan         String
  amount       Float
  status       String    @default("PENDING")
  transferCode String    @unique
  sepayRef     String?
  qrUrl        String
  expiresAt    DateTime
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String
  content    String
  toolCalls  Json?
  toolResult Json?
  actionType String?
  payload    Json?
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model FinanceKnowledge {
  id        String                       @id @default(cuid())
  title     String
  content   String
  chunk     String
  category  String
  embedding Unsupported("vector(1024)")?
  metadata  Json?
  createdAt DateTime                     @default(now())

  @@map("finance_knowledge")
}

model Article {
  id        String   @id @default(cuid())
  title     String
  author    String   @default("FinSight Team")
  date      String
  imageUrl  String
  excerpt   String
  content   String   @db.Text
  category  String   @default("STORY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("articles")
}

model AIStrategy {
  id             String   @id @default(cuid())
  userId         String
  sentimentValue Int
  sentimentLabel String
  riskLevel      String
  savings        Float
  gold           Float
  stocks         Float
  stocks_us      Float    @default(0)
  bonds          Float
  crypto         Float
  recommendation String   @db.Text
  marketViews    Json?
  createdAt      DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userPortfolio UserPortfolio?

  @@map("ai_strategies")
}

model UserPortfolio {
  id               String   @id @default(cuid())
  userId           String   @unique
  sourceStrategyId String?  @unique
  savings          Float
  gold             Float
  stocks           Float
  stocks_us        Float    @default(0)
  bonds            Float
  crypto         Float
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceStrategy AIStrategy? @relation(fields: [sourceStrategyId], references: [id])

  @@map("user_portfolios")
}

model Wallet {
  id                String    @id @default(cuid())
  userId            String
  name              String
  type              String    @default("CASH")
  icon              String?
  color             String?   @default("#3b82f6")
  balance           Float     @default(0)
  isDefault         Boolean   @default(false)
  bankName          String?
  bankAccountNumber String?
  sepayToken        String?
  sepayLinkedAt     DateTime?
  lastSyncedTxId    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses     Expense[]
  bankTransactionsPending BankTransactionPending[]

  @@map("wallets")
}

model BankTransactionPending {
  id              String   @id @default(cuid())
  userId          String
  walletId        String
  sepayTxId       String
  amount          Float
  type            String
  transactionDate DateTime
  description     String?
  bankBrandName   String?
  accountNumber   String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, sepayTxId])
  @@map("bank_transactions_pending")
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   @default("EXPENSE")
  categoryId  String
  walletId    String?
  date        DateTime @default(now())
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  wallet   Wallet?         @relation(fields: [walletId], references: [id])

  @@map("expenses")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  userId    String?
  parentId  String?
  name      String
  icon      String?
  color     String?
  type      String   @default("EXPENSE")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user     User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ExpenseCategory[] @relation("CategoryHierarchy")
  expenses Expense[]

  @@map("expense_categories")
}

model CommissionLog {
  id              String   @id @default(cuid())
  recipientId     String
  payerId         String
  transactionId   String
  commissionAmount Float
  originalAmount  Float
  commissionRate  Float
  plan            String
  status          String   @default("EARNED")
  createdAt       DateTime @default(now())

  recipient User @relation("CommissionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("commission_logs")
}

model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankCode      String
  bankName      String
  bankShortName String
  bankLogo      String?
  accountNumber String
  accountName   String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawalRequests WithdrawalRequest[]

  @@map("bank_accounts")
}

model WithdrawalRequest {
  id            String   @id @default(cuid())
  userId        String
  bankAccountId String
  amount        Float
  status        String   @default("PENDING")
  adminNote     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@map("withdrawal_requests")
}

model Referral {
  id               String   @id @default(cuid())
  referrerId       String
  referredId       String   @unique
  status           String   @default("PENDING")
  hasToppedUp      Boolean  @default(false)
  activeDaysCount  Int      @default(0)
  rewardedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referee", fields: [referredId], references: [id], onDelete: Cascade)

  @@map("referrals")
}

model ReferralClick {
  id         String   @id @default(cuid())
  referrerId String
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  referrer User @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@map("referral_clicks")
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  date      String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("user_activities")
}

model KycRecord {
  id             String   @id @default(cuid())
  userId         String   @unique
  idNumber       String
  fullName       String
  dob            String
  sex            String
  address        String
  issueDate      String
  issueLoc       String
  fptFrontRaw    Json?
  fptBackRaw     Json?
  livenessRaw    Json?
  isLive         Boolean  @default(false)
  faceMatchScore String?
  status         String   @default("PENDING")
  rejectReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_records")
}

model FaceDescriptor {
  id          String                       @id @default(cuid())
  userId      String
  descriptor  Unsupported("vector(128)")
  createdAt   DateTime                     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("face_descriptors")
}
