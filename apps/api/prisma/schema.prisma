  levelExpiresAt DateTime?
  strategyQuota  Int       @default(10) // Số lượt tạo chiến lược AI còn lại
  referralCode   String?   @unique
  referralCodeUsed String?   // Mã đã dùng khi đăng ký
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  twoFactorSecret String?
  isTwoFactorEnabled Boolean @default(false)
  twoFactorBackupCodes String? // Serialized JSON array of backup codes
  
  debts           Debt[]
  investorProfile InvestorProfile?
  notifications   Notification[]
  debtSnapshots   DebtSnapshot[]
