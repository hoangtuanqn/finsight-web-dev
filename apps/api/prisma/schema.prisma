model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  userAgent String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trusted_devices")
}

model Debt {
  id               String    @id @default(cuid())
  userId           String
  name             String
  platform         String
  originalAmount   Float
  balance          Float
  apr              Float
  rateType         String    @default("FLAT")
  feeProcessing    Float     @default(0)
  feeInsurance     Float     @default(0)
  feeManagement    Float     @default(0)
  feePenaltyPerDay Float     @default(0)
  minPayment       Float
  dueDay           Int
  termMonths       Int
  remainingTerms   Int
  startDate        DateTime?
  status           String    @default("ACTIVE")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // ── Smart Deletion System ──
  deletedAt        DateTime? // Thời điểm user thực hiện xoá mềm
  scheduledPurgeAt DateTime? // Thời điểm Cronjob sẽ Hard Delete
  deleteReason     String? // Lý do xoá
  deleteCommitment Boolean   @default(false) // Trạng thái đã xác nhận rủi ro

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]
  repaymentPlanItems RepaymentPlanItem[]

  @@map("debts")
}

model Payment {
  id     String   @id @default(cuid())
  debtId String
  amount Float
  paidAt DateTime @default(now())
  notes  String?

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model InvestorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  capital       Float    @default(0)
  monthlyAdd    Float    @default(0)
  goal          String   @default("GROWTH")
  horizon       String   @default("MEDIUM")
  riskLevel     String   @default("MEDIUM")
  riskScore     Int      @default(0)
  savingsRate   Float    @default(6.0)
  inflationRate Float    @default(3.5)
  lastUpdated   DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations Allocation[]

  @@map("investor_profiles")
}

model Allocation {
  id             String   @id @default(cuid())
  profileId      String
  sentimentValue Int
  sentimentLabel String
  savings        Float
  gold           Float
  stocks         Float
  stocks_us      Float    @default(0)
  bonds          Float
  crypto         Float
  recommendation String
  createdAt      DateTime @default(now())

  profile InvestorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("allocations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  severity  String   @default("INFO")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DebtSnapshot {
  id           String   @id @default(cuid())
  userId       String
  totalDebt    Float
  totalEAR     Float
  debtToIncome Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debt_snapshots")
}

model DebtGoal {
  id         String   @id @default(cuid())
  userId     String   @unique
  targetDate DateTime
  strategy   String   @default("AVALANCHE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debt_goals")
}

model RepaymentPlan {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  strategy    String   @default("CUSTOM")
  extraBudget Float    @default(0)
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items RepaymentPlanItem[]

  @@map("repayment_plans")
}

model RepaymentPlanItem {
  id        String   @id @default(cuid())
  planId    String
  debtId    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  plan RepaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  debt Debt          @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@unique([planId, debtId])
  @@map("repayment_plan_items")
}

// ── Subscription & Payment ──────────────────────────────────

model Transaction {
  id           String    @id @default(cuid())
  userId       String
  plan         String // PRO | PROMAX
  amount       Float
  status       String    @default("PENDING") // PENDING | PAID | EXPIRED | CANCELLED
  transferCode String    @unique
  sepayRef     String?
  qrUrl        String
  expiresAt    DateTime
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ── Agentic AI: Chat & RAG Models ──────────────────────────

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String? // Auto-generated từ message đầu tiên
  metadata  Json? // Lưu context bổ sung
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String // "user" | "assistant" | "tool" | "system"
  content    String // Nội dung tin nhắn
  toolCalls  Json? // Lưu tool calls nếu có
  toolResult Json? // Kết quả tool execution
  actionType String? // "text_response" | "form_population"
  payload    Json? // trigger_payload cho form_population
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model FinanceKnowledge {
  id        String                       @id @default(cuid())
  title     String
  content   String // Nội dung gốc
  chunk     String // Đoạn đã chunk
  category  String // "CONCEPT" | "REGULATION" | "STRATEGY"
  embedding Unsupported("vector(1024)")? // pgvector embedding
  metadata  Json?
  createdAt DateTime                     @default(now())

  @@map("finance_knowledge")
}

model Article {
  id        String   @id @default(cuid())
  title     String
  author    String   @default("FinSight Team")
  date      String
  imageUrl  String
  excerpt   String
  content   String   @db.Text
  category  String   @default("STORY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // ── Investment Strategy ─────────────────────────────────────

  @@map("articles")
}

model AIStrategy {
  id             String   @id @default(cuid())
  userId         String
  sentimentValue Int
  sentimentLabel String
  riskLevel      String
  savings        Float
  gold           Float
  stocks         Float
  stocks_us      Float    @default(0)
  bonds          Float
  crypto         Float
  recommendation String   @db.Text
  marketViews    Json?
  createdAt      DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userPortfolio UserPortfolio?

  @@map("ai_strategies")
}

model UserPortfolio {
  id               String   @id @default(cuid())
  userId           String   @unique
  sourceStrategyId String?  @unique
  savings          Float
  gold             Float
  stocks           Float
  stocks_us        Float    @default(0)
  bonds            Float
  crypto           Float
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceStrategy AIStrategy? @relation(fields: [sourceStrategyId], references: [id])

  @@map("user_portfolios")
}
// ── Expense Management ─────────────────────────────────────

model Wallet {
  id                String    @id @default(cuid())
  userId            String
  name              String
  type              String    @default("CASH") // CASH | BANK | EWALLET | OTHER
  icon              String?   // emoji icon
  color             String?   @default("#3b82f6")
  balance           Float     @default(0)
  isDefault         Boolean   @default(false)
  // Bank & SePay sync fields
  bankName          String?   // Tên ngân hàng (e.g. "TPBank", "Vietcombank")
  bankAccountNumber String?   // Số tài khoản ngân hàng
  sepayToken        String?   // Token API SePay của người dùng
  sepayLinkedAt     DateTime? // Thời điểm liên kết SePay
  lastSyncedTxId    String?   // ID giao dịch SePay cuối đã đồng bộ (dùng làm since_id)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses     Expense[]
  bankTransactionsPending BankTransactionPending[]

  @@map("wallets")
}

// Giao dịch ngân hàng địa từ SePay — chờ user duyệt
model BankTransactionPending {
  id              String   @id @default(cuid())
  userId          String
  walletId        String
  sepayTxId       String   // ID gốc từ SePay (unique per wallet)
  amount          Float
  type            String   // INCOME | EXPENSE
  transactionDate DateTime
  description     String?
  bankBrandName   String?
  accountNumber   String?
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED
  createdAt       DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, sepayTxId])
  @@map("bank_transactions_pending")
}

model Expense {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  type        String   @default("EXPENSE") // EXPENSE | INCOME
  categoryId  String
  walletId    String?
  date        DateTime @default(now())
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  wallet   Wallet?         @relation(fields: [walletId], references: [id])

  @@map("expenses")
}

model ExpenseCategory {
  id        String   @id @default(cuid())
  userId    String?  // null = system default
  parentId  String?  // null = top-level group
  name      String
  icon      String?  // emoji icon
  color     String?  // Hex color
  type      String   @default("EXPENSE") // EXPENSE | INCOME
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  user     User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   ExpenseCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ExpenseCategory[] @relation("CategoryHierarchy")
  expenses Expense[]

  @@map("expense_categories")
}
// ── Affiliate & Referral ──────────────────────────────────
model Referral {
  id               String   @id @default(cuid())
  referrerId       String
  referredId       String   @unique
  status           String   @default("PENDING") // PENDING | QUALIFIED | REWARDED
  hasToppedUp      Boolean  @default(false)
  activeDaysCount  Int      @default(0)
  rewardedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("Referee", fields: [referredId], references: [id], onDelete: Cascade)

  @@map("referrals")
}

model ReferralClick {
  id         String   @id @default(cuid())
  referrerId String
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  referrer User @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  @@map("referral_clicks")
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  date      String   // Định dạng YYYY-MM-DD để dễ quản lý unique per day

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("user_activities")
}
