{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "../dist",
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": ["**/*"],
  "exclude": ["node_modules", "../dist"]
}
