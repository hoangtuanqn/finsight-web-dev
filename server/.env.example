# ── Database ──
DATABASE_URL="postgresql://postgres:password@localhost:5432/finsight_db"

# ── Redis ──
REDIS_URL="redis://localhost:6379"

# ── JWT ──
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="7d"

# ── Server ──
PORT=5001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# ══════════════════════════════════════════════
# ── LLM Provider Configuration ──
# ══════════════════════════════════════════════

# ── Default: FPT Cloud SaoLa4 (OpenAI-compatible) ──
LLM_PROVIDER=fptcloud
LLM_MODEL=SaoLa4-medium
LLM_BASE_URL=https://mkp-api.fptcloud.com
LLM_API_KEY=your-fpt-api-key-here

# ── Alternative: OpenAI ──
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-your-openai-key-here

# ── Alternative: Google Gemini ──
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=AIza-your-google-key-here

# ── Alternative: Local (Ollama) ──
# LLM_PROVIDER=local
# LLM_MODEL=llama3
# LLM_BASE_URL=http://localhost:11434

# ══════════════════════════════════════════════
# ── Embedding Configuration ──
# ══════════════════════════════════════════════
EMBEDDING_PROVIDER=fptcloud
EMBEDDING_MODEL=Vietnamese_Embedding
