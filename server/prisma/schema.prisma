generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String?
  googleId        String?   @unique
  facebookId      String?   @unique
  avatar          String?
  fullName        String
  monthlyIncome   Float     @default(0)
  extraBudget     Float     @default(0)
  level           String    @default("BASIC") // BASIC | PRO | PROMAX
  levelExpiresAt  DateTime?
  strategyQuota   Int       @default(10)      // Số lượt tạo chiến lược AI còn lại
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  debts           Debt[]
  investorProfile InvestorProfile?
  notifications   Notification[]
  debtSnapshots   DebtSnapshot[]
  chatSessions    ChatSession[]
  debtGoal        DebtGoal?
  transactions    Transaction[]
  aiStrategies    AIStrategy[]
  userPortfolio   UserPortfolio?

  @@map("users")
}

model Debt {
  id               String   @id @default(cuid())
  userId           String
  name             String
  platform         String
  originalAmount   Float
  balance          Float
  apr              Float
  rateType         String   @default("FLAT")
  feeProcessing    Float    @default(0)
  feeInsurance     Float    @default(0)
  feeManagement    Float    @default(0)
  feePenaltyPerDay Float    @default(0)
  minPayment       Float
  dueDay           Int
  termMonths       Int
  remainingTerms   Int
  startDate        DateTime?
  status                 String    @default("ACTIVE")
  notes                  String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // ── Smart Deletion System ──
  deletedAt              DateTime? // Thời điểm user thực hiện xoá mềm
  scheduledPurgeAt       DateTime? // Thời điểm Cronjob sẽ Hard Delete
  deleteReason           String?   // Lý do xoá
  deleteCommitment       Boolean   @default(false) // Trạng thái đã xác nhận rủi ro


  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@map("debts")
}

model Payment {
  id     String   @id @default(cuid())
  debtId String
  amount Float
  paidAt DateTime @default(now())
  notes  String?

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model InvestorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  capital     Float    @default(0)
  monthlyAdd  Float    @default(0)
  goal        String   @default("GROWTH")
  horizon     String   @default("MEDIUM")
  riskLevel     String   @default("MEDIUM")
  riskScore     Int      @default(0)
  savingsRate   Float    @default(6.0)
  inflationRate Float    @default(3.5)
  lastUpdated   DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocations Allocation[]

  @@map("investor_profiles")
}

model Allocation {
  id             String   @id @default(cuid())
  profileId      String
  sentimentValue Int
  sentimentLabel String
  savings        Float
  gold           Float
  stocks         Float
  bonds          Float
  crypto         Float
  recommendation String
  createdAt      DateTime @default(now())

  profile InvestorProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("allocations")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  severity  String   @default("INFO")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model DebtSnapshot {
  id           String   @id @default(cuid())
  userId       String
  totalDebt    Float
  totalEAR     Float
  debtToIncome Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debt_snapshots")
}

model DebtGoal {
  id         String   @id @default(cuid())
  userId     String   @unique
  targetDate DateTime
  strategy   String   @default("AVALANCHE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("debt_goals")
}

// ── Subscription & Payment ──────────────────────────────────

model Transaction {
  id           String    @id @default(cuid())
  userId       String
  plan         String    // PRO | PROMAX
  amount       Float
  status       String    @default("PENDING") // PENDING | PAID | EXPIRED | CANCELLED
  transferCode String    @unique
  sepayRef     String?
  qrUrl        String
  expiresAt    DateTime
  paidAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ── Agentic AI: Chat & RAG Models ──────────────────────────

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String?  // Auto-generated từ message đầu tiên
  metadata  Json?    // Lưu context bổ sung
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id         String   @id @default(cuid())
  sessionId  String
  role       String   // "user" | "assistant" | "tool" | "system"
  content    String   // Nội dung tin nhắn
  toolCalls  Json?    // Lưu tool calls nếu có
  toolResult Json?    // Kết quả tool execution
  actionType String?  // "text_response" | "form_population"
  payload    Json?    // trigger_payload cho form_population
  createdAt  DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model FinanceKnowledge {
  id        String                      @id @default(cuid())
  title     String
  content   String                      // Nội dung gốc
  chunk     String                      // Đoạn đã chunk
  category  String                      // "CONCEPT" | "REGULATION" | "STRATEGY"
  embedding Unsupported("vector(1024)")? // pgvector embedding
  metadata  Json?
  createdAt DateTime                    @default(now())

  @@map("finance_knowledge")
}

model Article {
  id        String   @id @default(cuid())
  title     String
  author    String   @default("FinSight Team")
  date      String
  imageUrl  String
  excerpt   String
  content   String   @db.Text
  category  String   @default("STORY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("articles")
// ── Investment Strategy ─────────────────────────────────────

model AIStrategy {
  id             String   @id @default(cuid())
  userId         String
  sentimentValue Int
  sentimentLabel String
  riskLevel      String
  savings        Float
  gold           Float
  stocks         Float
  bonds          Float
  crypto         Float
  recommendation String   @db.Text
  createdAt      DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userPortfolio UserPortfolio?

  @@map("ai_strategies")
}

model UserPortfolio {
  id               String    @id @default(cuid())
  userId           String    @unique
  sourceStrategyId String?   @unique
  savings          Float
  gold             Float
  stocks           Float
  bonds            Float
  crypto           Float
  notes            String?   @db.Text
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceStrategy AIStrategy? @relation(fields: [sourceStrategyId], references: [id])

  @@map("user_portfolios")
}
